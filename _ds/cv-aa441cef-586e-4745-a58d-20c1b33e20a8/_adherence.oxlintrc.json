{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/foundation/**",
              "components/resume/**",
              "ui_kits/resume/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Outfit|DM Sans|Be Vietnam Pro))/i]",
        "message": "Font not provided by the design system. Available: Outfit, DM Sans, Be Vietnam Pro."
      },
      {
        "selector": "JSXOpeningElement[name.name='Aside'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|role|avatar|quote|contacts|socials|languages|key|ref|className|style|children)$/]",
        "message": "<Aside> doesn't accept that prop. Declared props: name, role, avatar, quote, contacts, socials, languages."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|size|ring|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, size, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|accent|blue|neutral)$/]",
        "message": "<Badge> tone must be one of 'success' | 'accent' | 'blue' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|href|key|ref|className|style|children)$/]",
        "message": "<ContactRow> doesn't accept that prop. Declared props: icon, label, value, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:vertical|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: vertical."
      },
      {
        "selector": "JSXOpeningElement[name.name='EducationLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:img|label|bg|shadow|key|ref|className|style|children)$/]",
        "message": "<EducationLogo> doesn't accept that prop. Declared props: img, label, bg, shadow."
      },
      {
        "selector": "JSXOpeningElement[name.name='EducationLogo'] > JSXAttribute[name.name='shadow'] > Literal[value!=/^(?:none|coral|yellow|green|blue)$/]",
        "message": "<EducationLogo> shadow must be one of 'none' | 'coral' | 'yellow' | 'green' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ExperienceLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:img|label|bg|key|ref|className|style|children)$/]",
        "message": "<ExperienceLogo> doesn't accept that prop. Declared props: img, label, bg."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|bg|color|size|radius|shadow|img|alt|children|key|ref|className|style|children)$/]",
        "message": "<IconTile> doesn't accept that prop. Declared props: label, bg, color, size, radius, shadow, img, alt, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconTile'] > JSXAttribute[name.name='shadow'] > Literal[value!=/^(?:none|coral|yellow|green|blue)$/]",
        "message": "<IconTile> shadow must be one of 'none' | 'coral' | 'yellow' | 'green' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LanguageRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:flag|language|level|key|ref|className|style|children)$/]",
        "message": "<LanguageRow> doesn't accept that prop. Declared props: flag, language, level."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|title|description|linkLabel|href|linkIcon|key|ref|className|style|children)$/]",
        "message": "<ProjectCard> doesn't accept that prop. Declared props: image, title, description, linkLabel, href, linkIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Quote'] > JSXAttribute > JSXIdentifier[name!=/^(?:author|children|key|ref|className|style|children)$/]",
        "message": "<Quote> doesn't accept that prop. Declared props: author, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionTitle'] > JSXAttribute > JSXIdentifier[name!=/^(?:marker|color|children|key|ref|className|style|children)$/]",
        "message": "<SectionTitle> doesn't accept that prop. Declared props: marker, color, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:solid|items|children|key|ref|className|style|children)$/]",
        "message": "<SkillChip> doesn't accept that prop. Declared props: solid, items, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillGroup'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|columns|children|key|ref|className|style|children)$/]",
        "message": "<SkillGroup> doesn't accept that prop. Declared props: icon, label, columns, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:network|handle|href|key|ref|className|style|children)$/]",
        "message": "<SocialLink> doesn't accept that prop. Declared props: network, handle, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='SocialLink'] > JSXAttribute[name.name='network'] > Literal[value!=/^(?:github|linkedin|facebook)$/]",
        "message": "<SocialLink> network must be one of 'github' | 'linkedin' | 'facebook'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToolLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:img|label|bg|shadow|key|ref|className|style|children)$/]",
        "message": "<ToolLogo> doesn't accept that prop. Declared props: img, label, bg, shadow."
      },
      {
        "selector": "JSXOpeningElement[name.name='ToolLogo'] > JSXAttribute[name.name='shadow'] > Literal[value!=/^(?:none|coral|yellow|green|blue)$/]",
        "message": "<ToolLogo> shadow must be one of 'none' | 'coral' | 'yellow' | 'green' | 'blue'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
